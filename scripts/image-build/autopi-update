#!/usr/bin/env bash
# AutoPi over-the-air update helper (pi_hosted Docker deployment).
#
# Pulls the latest source into the on-device checkout, then redeploys the
# running copies from it: the containerized app AND the host-side pieces the
# image does not carry (the Stream Deck controller, the GPIO/appliance compose
# override). Run as root; it writes under /opt and restarts systemd units.
# Prints a human log to stderr and, as its LAST line on stdout, one JSON object
# the host-bridge relays to the UI.
#
#   sudo /opt/autopi-src/scripts/image-build/autopi-update
#
# Follows docs/design/pi-appliance-blueprint.md section 5:
#   - Re-exec the fresh copy of THIS script after the pull, so a change to the
#     updater itself takes effect on the same run (an in-place overwrite does
#     not change the already-running shell). This is why earlier fixes did not
#     apply on the first update press.
#   - Sync the host-side pieces (deck package, compose override) separately from
#     the Docker step; the image pull never touches them.
#   - Idempotent and re-runnable: it does not gate on the pull moving HEAD, and
#     it recovers a diverged checkout by resetting to origin.
set -uo pipefail

REPO_DIR="${REPO_DIR:-/opt/autopi-src}"
BRANCH="${REPO_BRANCH:-main}"
SELF="$REPO_DIR/scripts/image-build/autopi-update"
result="unknown"; detail=""; changed="false"

log() { printf '%s\n' "$*" >&2; }
emit() {  # always the last line on stdout
  printf '{"ok": %s, "result": "%s", "changed": %s, "detail": "%s"}\n' \
    "$1" "$result" "$changed" "$(printf '%s' "$detail" | sed 's/"/\\"/g')"
}

[ -d "$REPO_DIR/.git" ] || { result="no-checkout"; detail="No git checkout at $REPO_DIR"; log "$detail"; emit false; exit 1; }

# --- pull the update source (recover a diverged checkout) --------------------
before="$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null || echo none)"
log "Fetching latest source in $REPO_DIR"
git -C "$REPO_DIR" fetch --depth 1 origin "$BRANCH" >&2 || log "fetch failed; using what is on disk"
if ! git -C "$REPO_DIR" merge --ff-only "origin/$BRANCH" >&2 2>&1; then
  log "Fast-forward not possible; resetting the checkout to origin/$BRANCH"
  git -C "$REPO_DIR" reset --hard "origin/$BRANCH" >&2 || log "reset failed; using what is on disk"
fi
after="$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null || echo none)"
[ "$before" != "$after" ] && changed="true"
# Carry the "did the pull change anything" status across a re-exec so the final
# report is accurate even though the re-run's own pull is a no-op.
[ "${AUTOPI_UPDATE_CHANGED:-}" = "true" ] && changed="true"

# --- re-exec the fresh updater once (blueprint 5) ----------------------------
if [ "$changed" = "true" ] && [ -z "${AUTOPI_UPDATE_REEXEC:-}" ] && [ -f "$SELF" ]; then
  log "Updater changed; re-executing the fresh copy"
  AUTOPI_UPDATE_REEXEC=1 AUTOPI_UPDATE_CHANGED=true exec bash "$SELF"
fi

# --- host-side pieces the Docker image does not carry ------------------------
# Compose override (network_mode host + this Pi's GPIO devices). Written before
# the container step so `docker compose up` picks it up.
if [ -f "$REPO_DIR/scripts/image-build/write-appliance-override.sh" ]; then
  bash "$REPO_DIR/scripts/image-build/write-appliance-override.sh" "$REPO_DIR" >&2 || true
fi

# --- the containerized app ---------------------------------------------------
log "Rebuilding and starting the stack"
if ! ( cd "$REPO_DIR" && docker compose up -d --build ) >&2; then
  result="compose-failed"; detail="docker compose up failed"; log "$detail"; emit false; exit 1
fi
sync || true

# --- Stream Deck controller (host-side, separate from the image) -------------
if systemctl list-unit-files 2>/dev/null | grep -q '^autopi-streamdeck.service'; then
  log "Refreshing the Stream Deck controller"
  if [ -d "$REPO_DIR/streamdeck/autopi_streamdeck" ] && [ -d /opt/autopi/streamdeck ]; then
    rm -rf /opt/autopi/streamdeck/autopi_streamdeck
    cp -a "$REPO_DIR/streamdeck/autopi_streamdeck" /opt/autopi/streamdeck/
    if [ -f /opt/autopi/streamdeck-venv/bin/pip ]; then
      /opt/autopi/streamdeck-venv/bin/pip install -q -r "$REPO_DIR/streamdeck/requirements.txt" >&2 || true
    fi
  fi
  # Regenerate the unit so an old install picks up StartLimitIntervalSec=0 and
  # the local-data-dir env, then clear any failed state a past crash loop left
  # (which was blocking a manual restart from recovering the deck).
  bash "$REPO_DIR/scripts/image-build/write-streamdeck-unit.sh" "$REPO_DIR" >&2 || true
  systemctl reset-failed autopi-streamdeck.service >&2 2>&1 || true
  systemctl restart autopi-streamdeck.service >&2 || log "deck restart failed"
fi

# --- host-bridge (long-running daemon: install file, detached restart) -------
if systemctl list-unit-files 2>/dev/null | grep -q '^autopi-host-bridge.service'; then
  install -m 755 "$REPO_DIR/scripts/image-build/autopi-host-bridge" /usr/local/sbin/autopi-host-bridge 2>/dev/null || true
  # Detached so restarting the bridge does not kill this updater (its child).
  systemd-run --collect --on-active=3s --unit="autopi-bridge-restart-$(date +%s)" \
    systemctl restart autopi-host-bridge.service >&2 2>&1 || true
fi

if [ "$changed" = "true" ]; then
  result="updated"; detail="Update complete"
else
  result="up-to-date"; detail="Already up to date; redeployed current version"
fi
log "$detail"
emit true
exit 0
