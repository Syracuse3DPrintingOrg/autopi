#!/usr/bin/env python3
"""AutoPi host-bridge: the narrow root helper the container calls for host ops.

Runs as root on the host (not in a container), bound to 127.0.0.1:9299 only.
The app reaches it over loopback because the appliance compose runs the app
with network_mode: host. It performs exactly the privileged operations a
container cannot: OTA update, reboot, restarting the Stream Deck service, and
reading Pi health and hardware presence.

Trust model (docs/design/pi-appliance-blueprint.md section 1):
  - A random token is written to INSTALL_DIR/data/bridge-token at startup, mode
    644 in a root-owned dir (the directory is the boundary, not the file mode).
    State-changing routes require it back as X-Bridge-Token.
  - Read-only status GETs are token-exempt.
  - Grace period: a request with NO token is allowed and logged for this
    release, so a device that updates its bridge before its app does not lock
    itself out. A WRONG token is always denied.
  - Privileged restarts run detached via systemd-run so restarting a unit never
    kills the request (or this bridge, the updater's parent).

Stdlib only, so it runs on a bare Pi OS Lite with no venv.
"""
from __future__ import annotations

import json
import os
import secrets
import shutil
import socket
import subprocess
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

INSTALL_DIR = os.environ.get("AUTOPI_INSTALL_DIR", "/opt/autopi")
REPO_DIR = os.environ.get("AUTOPI_REPO_DIR", "/opt/autopi-src")
# The token must live in the app's data dir, which is bind-mounted into the
# container, so the app reads the same file the bridge wrote. Defaults to the
# checkout's service/data (mounted to /app/data in the container).
TOKEN_PATH = os.environ.get("AUTOPI_BRIDGE_TOKEN_PATH",
                            os.path.join(REPO_DIR, "service", "data", "bridge-token"))
HOST, PORT = "127.0.0.1", 9299

# Bump this whenever the bridge gains or changes routes. The app compares it to
# the version it expects and tells the user to restart a stale bridge (a
# restart is what actually loads a newly-installed bridge file). 2 = network
# (Wi-Fi) routes added. 3 = CAN interface up/down/status routes added.
BRIDGE_VERSION = 3

# Grace: allow a tokenless request for this release so a bridge that updates
# ahead of the app does not lock the fleet out mid-update. Flip to False one
# release after every caller ships the token header.
ALLOW_TOKENLESS = True

# Routes that need no token: nothing a local process could not already learn.
PUBLIC_GETS = {"/system/health", "/hardware/status", "/health", "/network/status"}

TOKEN = ""


def _write_token() -> str:
    global TOKEN
    TOKEN = secrets.token_hex(24)
    try:
        os.makedirs(os.path.dirname(TOKEN_PATH), exist_ok=True)
        with open(TOKEN_PATH, "w") as f:
            f.write(TOKEN)
        os.chmod(TOKEN_PATH, 0o644)  # directory is the boundary, not the file
    except OSError as exc:
        print(f"bridge: could not write token file: {exc}", flush=True)
    return TOKEN


def _find_helper(name: str) -> str | None:
    """Self-heal: locate a helper in the checkout so an old device can grow it."""
    for base in (os.path.join(REPO_DIR, "scripts", "image-build"), "/usr/local/sbin", "/usr/local/bin"):
        cand = os.path.join(base, name)
        if os.path.exists(cand):
            return cand
    return None


def _detached_restart(unit: str, delay: int = 3, reason: str = "") -> None:
    """Restart a unit out-of-band so it never tears down this request/process."""
    print(f"bridge: scheduling restart of {unit} (reason={reason or 'unspecified'})", flush=True)
    tag = f"autopi-restart-{int(time.time() * 1000)}"
    if shutil.which("systemd-run"):
        subprocess.run(["systemd-run", "--collect", f"--on-active={delay}s",
                        f"--unit={tag}", "systemctl", "restart", unit], check=False)
    else:
        subprocess.Popen(["/bin/sh", "-c", f"sleep {delay}; systemctl restart {unit}"],
                         start_new_session=True)


def _run(cmd: list[str], timeout: float = 15) -> tuple[int, str, str]:
    """Run a command, never raising. Returns (returncode, stdout, stderr)."""
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.returncode, r.stdout, r.stderr
    except (OSError, subprocess.SubprocessError) as exc:
        return -1, "", str(exc)


def _have(cmd: str) -> bool:
    return shutil.which(cmd) is not None


# --- pure parsing (importable and testable without root or hardware) --------
def parse_nmcli_active_ssid(output: str) -> str | None:
    """Parse `nmcli -t -f active,ssid dev wifi` for the SSID of the active AP."""
    for line in output.splitlines():
        parts = line.split(":")
        if len(parts) >= 2 and parts[0] == "yes" and parts[1]:
            return parts[1]
    return None


def parse_iw_link_ssid(output: str) -> str | None:
    """Parse `iw dev wlan0 link` for the connected SSID, as a fallback."""
    for line in output.splitlines():
        line = line.strip()
        if line.startswith("SSID:"):
            return line.split(":", 1)[1].strip() or None
    return None


def parse_nmcli_scan(output: str) -> list[dict]:
    """Parse `nmcli -t -f ssid,signal,security dev wifi list` into networks.

    nmcli escapes literal ':' inside a field as '\\:', which this splits on an
    unescaped colon only. Duplicate SSIDs (seen on more than one channel) keep
    the strongest signal and drop the rest.
    """
    import re

    best: dict[str, dict] = {}
    for line in output.splitlines():
        if not line.strip():
            continue
        parts = re.split(r"(?<!\\):", line)
        parts = [p.replace("\\:", ":") for p in parts]
        ssid = parts[0].strip() if parts else ""
        if not ssid:
            continue
        signal = None
        if len(parts) > 1 and parts[1].strip().isdigit():
            signal = int(parts[1].strip())
        secured = bool(len(parts) > 2 and parts[2].strip() and parts[2].strip() != "--")
        prev = best.get(ssid)
        if prev is None or (signal or 0) > (prev["signal"] or 0):
            best[ssid] = {"ssid": ssid, "signal": signal, "secured": secured}
    return sorted(best.values(), key=lambda n: n["signal"] or 0, reverse=True)


def is_valid_can_interface(name: str) -> bool:
    """Guard for the ``interface`` field on every CAN route.

    Bringing an interface up or down needs root, so a bad name here is the
    one way an app-side bug (or a request replay) could reach past the
    intended can0/can1 into some other host network device. Linux interface
    names are at most 15 bytes (IFNAMSIZ - 1) and this only needs to admit
    the SocketCAN naming convention (canN, vcanN) plus anything a virtual/
    custom channel might reasonably be called.
    """
    import re

    return bool(name) and len(name) <= 15 and re.fullmatch(r"[A-Za-z0-9_.-]+", name) is not None


def parse_iw_scan(output: str) -> list[dict]:
    """Parse `iw dev wlan0 scan` into networks, as a fallback when nmcli is absent."""
    networks: list[dict] = []
    seen: set[str] = set()
    current_signal: float | None = None
    for raw in output.splitlines():
        line = raw.strip()
        if line.startswith("signal:"):
            try:
                current_signal = float(line.split(":", 1)[1].strip().split()[0])
            except (ValueError, IndexError):
                current_signal = None
        elif line.startswith("SSID:"):
            ssid = line.split(":", 1)[1].strip()
            if ssid and ssid not in seen:
                seen.add(ssid)
                networks.append({"ssid": ssid, "signal": current_signal, "secured": None})
    networks.sort(key=lambda n: n["signal"] if n["signal"] is not None else -999, reverse=True)
    return networks


# --- privileged operations ---------------------------------------------------
def op_update(_body: dict) -> dict:
    helper = _find_helper("autopi-update")
    if not helper:
        return {"ok": False, "error": "updater not found in checkout"}
    proc = subprocess.run(["bash", helper], capture_output=True, text=True, timeout=1800)
    # The updater's last stdout line is a JSON object; relay it.
    last = (proc.stdout or "").strip().splitlines()
    for line in reversed(last):
        line = line.strip()
        if line.startswith("{"):
            try:
                return json.loads(line)
            except ValueError:
                break
    return {"ok": proc.returncode == 0, "detail": (proc.stdout or proc.stderr or "").strip()[-500:]}


def op_reboot(_body: dict) -> dict:
    subprocess.Popen(["/bin/sh", "-c", "sleep 2; systemctl reboot"], start_new_session=True)
    return {"ok": True, "message": "Rebooting"}


def op_streamdeck_restart(_body: dict) -> dict:
    _detached_restart("autopi-streamdeck.service", reason="app request")
    return {"ok": True, "message": "Reconnecting the Stream Deck…"}


def op_network_status(_body: dict) -> dict:
    """Current SSID (if any), IP address, and hostname."""
    ssid = None
    if _have("nmcli"):
        rc, out, _err = _run(["nmcli", "-t", "-f", "active,ssid", "dev", "wifi"])
        if rc == 0:
            ssid = parse_nmcli_active_ssid(out)
    if ssid is None:
        rc, out, _err = _run(["iw", "dev", "wlan0", "link"])
        if rc == 0:
            ssid = parse_iw_link_ssid(out)
    ip = None
    rc, out, _err = _run(["hostname", "-I"])
    if rc == 0 and out.strip():
        ip = out.strip().split()[0]
    return {"ok": True, "ssid": ssid, "ip": ip, "hostname": socket.gethostname()}


def op_network_scan(_body: dict) -> dict:
    """Visible Wi-Fi networks, strongest signal first."""
    if _have("nmcli"):
        _run(["nmcli", "device", "wifi", "rescan"], timeout=15)  # best effort; ignore failure
        rc, out, err = _run(["nmcli", "-t", "-f", "ssid,signal,security", "dev", "wifi", "list"], timeout=20)
        if rc == 0:
            return {"ok": True, "networks": parse_nmcli_scan(out)}
        return {"ok": False, "error": (err or "nmcli scan failed").strip()[:500]}
    if _have("iw"):
        rc, out, err = _run(["iw", "dev", "wlan0", "scan"], timeout=20)
        if rc == 0:
            return {"ok": True, "networks": parse_iw_scan(out)}
        return {"ok": False, "error": (err or "iw scan failed").strip()[:500]}
    return {"ok": False, "error": "no Wi-Fi scanning tool available (need nmcli or iw)"}


def op_network_connect(body: dict) -> dict:
    """Join a Wi-Fi network by SSID, with an optional passphrase."""
    ssid = (body.get("ssid") or "").strip()
    psk = body.get("psk") or ""
    if not ssid:
        return {"ok": False, "error": "ssid is required"}
    if _have("nmcli"):
        cmd = ["nmcli", "device", "wifi", "connect", ssid]
        if psk:
            cmd += ["password", psk]
        rc, out, err = _run(cmd, timeout=30)
        if rc == 0:
            return {"ok": True, "message": f"Connected to {ssid}"}
        return {"ok": False, "error": (err or out or "nmcli connect failed").strip()[:500]}
    if _have("wpa_cli"):
        rc, out, _err = _run(["wpa_cli", "-i", "wlan0", "add_network"], timeout=10)
        net_id = out.strip().splitlines()[-1].strip() if rc == 0 and out.strip() else ""
        if not net_id.isdigit():
            return {"ok": False, "error": "could not add a wpa_supplicant network"}
        _run(["wpa_cli", "-i", "wlan0", "set_network", net_id, "ssid", f'"{ssid}"'], timeout=10)
        if psk:
            _run(["wpa_cli", "-i", "wlan0", "set_network", net_id, "psk", f'"{psk}"'], timeout=10)
        else:
            _run(["wpa_cli", "-i", "wlan0", "set_network", net_id, "key_mgmt", "NONE"], timeout=10)
        _run(["wpa_cli", "-i", "wlan0", "enable_network", net_id], timeout=10)
        rc, out, err = _run(["wpa_cli", "-i", "wlan0", "select_network", net_id], timeout=10)
        _run(["wpa_cli", "-i", "wlan0", "save_config"], timeout=10)
        if rc == 0:
            return {"ok": True, "message": f"Connecting to {ssid}"}
        return {"ok": False, "error": (err or out or "wpa_cli connect failed").strip()[:500]}
    return {"ok": False, "error": "no Wi-Fi tool available (need nmcli or wpa_cli)"}


def _ip_link_show(interface: str) -> dict:
    """Run `ip -details -json link show <interface>` and return the parsed
    JSON list, or an error. Read-only, so this needs no root at all; it is
    routed through the bridge anyway so the same code path works whether or
    not the app container shares the host's network namespace."""
    rc, out, err = _run(["ip", "-details", "-json", "link", "show", interface], timeout=5)
    if rc != 0:
        return {"ok": False, "error": (err or f"no such interface: {interface}").strip()[:500]}
    try:
        return {"ok": True, "link": json.loads(out)}
    except ValueError:
        return {"ok": False, "error": "could not parse ip link output"}


def op_can_up(body: dict) -> dict:
    """Bring a CAN interface up, setting its arbitration (and CAN-FD data)
    bitrate first. Mirrors what setup-can-waveshare.sh's boot-time helper
    does, but on demand and for one interface at a time."""
    interface = str(body.get("interface") or "").strip()
    if not is_valid_can_interface(interface):
        return {"ok": False, "error": "invalid interface name"}
    try:
        bitrate = int(body.get("bitrate") or 500000)
    except (TypeError, ValueError):
        return {"ok": False, "error": "bitrate must be a number"}
    fd = bool(body.get("fd"))
    data_bitrate = body.get("data_bitrate")
    _run(["ip", "link", "set", interface, "down"], timeout=5)  # best effort; may already be down
    type_cmd = ["ip", "link", "set", interface, "type", "can", "bitrate", str(bitrate)]
    if fd:
        try:
            data_bitrate = int(data_bitrate) if data_bitrate else bitrate
        except (TypeError, ValueError):
            return {"ok": False, "error": "data_bitrate must be a number"}
        type_cmd += ["dbitrate", str(data_bitrate), "fd", "on"]
    rc, _out, err = _run(type_cmd, timeout=10)
    if rc != 0:
        return {"ok": False, "error": (err or "could not configure the interface").strip()[:500]}
    rc, _out, err = _run(["ip", "link", "set", interface, "up"], timeout=10)
    if rc != 0:
        return {"ok": False, "error": (err or "could not bring the interface up").strip()[:500]}
    status = _ip_link_show(interface)
    return {"ok": True, "message": f"{interface} is up", **status}


def op_can_down(body: dict) -> dict:
    interface = str(body.get("interface") or "").strip()
    if not is_valid_can_interface(interface):
        return {"ok": False, "error": "invalid interface name"}
    rc, _out, err = _run(["ip", "link", "set", interface, "down"], timeout=10)
    if rc != 0:
        return {"ok": False, "error": (err or "could not bring the interface down").strip()[:500]}
    status = _ip_link_show(interface)
    return {"ok": True, "message": f"{interface} is down", **status}


def op_can_status(body: dict) -> dict:
    interface = str(body.get("interface") or "").strip()
    if not is_valid_can_interface(interface):
        return {"ok": False, "error": "invalid interface name"}
    return _ip_link_show(interface)


def read_health(_body: dict) -> dict:
    """Raw Pi power/thermal/disk read. Every probe degrades to unknown."""
    out: dict = {"throttled": None, "temp_c": None, "disk_percent": None}
    try:
        r = subprocess.run(["vcgencmd", "get_throttled"], capture_output=True, text=True, timeout=5)
        # Output looks like: throttled=0x50005
        val = r.stdout.strip().split("=", 1)[-1]
        out["throttled"] = int(val, 16) if val.startswith("0x") else int(val)
    except (OSError, ValueError, subprocess.SubprocessError):
        pass
    try:
        with open("/sys/class/thermal/thermal_zone0/temp") as f:
            out["temp_c"] = round(int(f.read().strip()) / 1000.0, 1)
    except (OSError, ValueError):
        pass
    try:
        st = os.statvfs("/")
        used = (st.f_blocks - st.f_bfree) / st.f_blocks * 100 if st.f_blocks else 0
        out["disk_percent"] = round(used, 1)
    except OSError:
        pass
    return out


def read_hardware(_body: dict) -> dict:
    """Display and Stream Deck presence from sysfs, no privileges required."""
    display = os.path.exists("/dev/dri/card0")
    deck = False
    try:
        for root, _dirs, files in os.walk("/sys/bus/usb/devices"):
            if "idVendor" in files:
                with open(os.path.join(root, "idVendor")) as f:
                    if f.read().strip().lower() == "0fd9":
                        deck = True
                        break
    except OSError:
        pass
    return {"display": display, "streamdeck": deck}


ROUTES = {
    ("POST", "/update"): op_update,
    ("POST", "/reboot"): op_reboot,
    ("POST", "/streamdeck/restart"): op_streamdeck_restart,
    ("GET", "/system/health"): read_health,
    ("GET", "/hardware/status"): read_hardware,
    ("GET", "/network/status"): op_network_status,
    ("POST", "/network/wifi/scan"): op_network_scan,
    ("POST", "/network/wifi/connect"): op_network_connect,
    ("POST", "/can/up"): op_can_up,
    ("POST", "/can/down"): op_can_down,
    ("POST", "/can/status"): op_can_status,
    ("GET", "/health"): lambda _body: {"ok": True, "bridge": "autopi",
                                       "version": BRIDGE_VERSION, "ts": time.time()},
}


class Handler(BaseHTTPRequestHandler):
    def log_message(self, *args):  # keep the journal quiet
        pass

    def _authorized(self, path: str) -> bool:
        if path in PUBLIC_GETS:
            return True
        sent = self.headers.get("X-Bridge-Token", "")
        if not sent:
            if ALLOW_TOKENLESS:
                print(f"bridge: tokenless request to {path} allowed (grace)", flush=True)
                return True
            return False
        return secrets.compare_digest(sent, TOKEN)

    def _reply(self, code: int, body: dict) -> None:
        data = json.dumps(body).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def _dispatch(self, method: str) -> None:
        path = self.path.split("?", 1)[0].rstrip("/") or "/"
        fn = ROUTES.get((method, path))
        if fn is None:
            self._reply(404, {"ok": False, "error": "not found"})
            return
        if not self._authorized(path):
            self._reply(401, {"ok": False, "error": "bad or missing bridge token"})
            return
        body: dict = {}
        if method == "POST":
            try:
                length = int(self.headers.get("Content-Length") or 0)
            except ValueError:
                length = 0
            if length:
                try:
                    parsed = json.loads(self.rfile.read(length))
                    if isinstance(parsed, dict):
                        body = parsed
                except ValueError:
                    body = {}
        try:
            self._reply(200, fn(body))
        except Exception as exc:  # never crash the bridge on one bad request
            self._reply(500, {"ok": False, "error": str(exc)})

    def do_GET(self):
        self._dispatch("GET")

    def do_POST(self):
        self._dispatch("POST")


def main() -> None:
    _write_token()
    print(f"autopi-host-bridge listening on {HOST}:{PORT}", flush=True)
    ThreadingHTTPServer((HOST, PORT), Handler).serve_forever()


if __name__ == "__main__":
    main()
